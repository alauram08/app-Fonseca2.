        <!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Carlos Fonseca: El Juego Histórico</title>
    <style>
        :root { --rojo: #ce1126; --negro: #000000; --gris: #1a1a1a; --blanco: #ffffff; }
        body { font-family: 'Arial', sans-serif; margin: 0; background: var(--negro); color: var(--blanco); text-align: center; overflow-x: hidden; }
        
        /* Contenedores de Pantalla */
        .pantalla { display: none; padding: 20px; min-height: 100vh; box-sizing: border-box; }
        .activa { display: block; animation: fadeIn 0.4s; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        
        /* Imágenes y Tarjetas */
        .img-juego { width: 100%; max-width: 400px; border: 3px solid var(--rojo); border-radius: 10px; margin: 15px 0; box-shadow: 0 0 15px var(--rojo); }
        .card { background: var(--gris); padding: 20px; border-radius: 15px; border-top: 5px solid var(--rojo); max-width: 500px; margin: 10px auto; }
        
        /* Botones */
        .btn { background: var(--rojo); color: white; border: none; padding: 15px; margin: 8px auto; border-radius: 5px; cursor: pointer; font-weight: bold; width: 90%; max-width: 300px; display: block; text-transform: uppercase; transition: 0.2s; }
        .btn:hover { background: #900; transform: scale(1.02); }
        .btn-volver { background: #444; margin-top: 20px; }

        /* Trivia y Puzzle */
        .opcion-viva { background: #222; padding: 12px; margin: 10px; border-radius: 8px; cursor: pointer; border: 1px solid var(--rojo); }
        .opcion-viva:hover { background: var(--rojo); }
        #contenedor-puzzle { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px; margin: 20px 0; }
        .pieza { background: var(--rojo); padding: 12px; border-radius: 5px; cursor: pointer; font-weight: bold; }
        #resultado-puzzle { border: 2px dashed var(--rojo); min-height: 50px; padding: 15px; margin: 15px 0; font-size: 1.2em; background: #111; }
    </style>
</head>
<body>

    <div id="menu" class="pantalla activa">
        <h1>CARLOS FONSECA</h1>
        <img src="https://upload.wikimedia.org/wikipedia/commons/6/6f/Carlos_Fonseca_Amador.jpg" class="img-juego">
        <div class="card">
            <p>Selecciona un nivel de Trivia:</p>
            <button class="btn" onclick="iniciarTrivia('facil')">🟢 NIVEL FÁCIL</button>
            <button class="btn" onclick="iniciarTrivia('medio')">🟡 NIVEL MEDIO</button>
            <button class="btn" onclick="iniciarTrivia('dificil')">🔴 NIVEL DIFÍCIL</button>
            <hr style="border: 0.5px solid #333;">
            <button class="btn" onclick="navegar('senderos')">🏔️ SENDEROS (HISTORIA)</button>
            <button class="btn" onclick="iniciarPuzzle()">🧩 ROMPECABEZAS</button>
        </div>
    </div>

    <div id="pantalla-trivia" class="pantalla">
        <h2 id="trivia-titulo">Cargando...</h2>
        <div class="card">
            <p id="pregunta-texto" style="font-size: 1.2em; min-height: 50px;"></p>
            <div id="opciones-contenedor"></div>
        </div>
