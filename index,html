<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Carlos Fonseca: El Juego</title>
    <style>
        :root { --rojo: #ce1126; --negro: #000000; --gris: #1a1a1a; --blanco: #ffffff; }
        body { font-family: 'Arial', sans-serif; margin: 0; background: var(--negro); color: var(--blanco); text-align: center; overflow-x: hidden; }
        .pantalla { display: none; padding: 20px; min-height: 100vh; box-sizing: border-box; }
        .activa { display: block; animation: slideIn 0.3s; }
        @keyframes slideIn { from { transform: translateX(100%); } to { transform: translateX(0); } }
        
        .img-juego { width: 100%; max-width: 400px; border: 3px solid var(--rojo); border-radius: 10px; margin: 15px 0; }
        .btn { background: var(--rojo); color: white; border: none; padding: 15px; margin: 8px auto; border-radius: 5px; cursor: pointer; font-weight: bold; width: 90%; max-width: 300px; display: block; text-transform: uppercase; }
        .btn:hover { background: #900; }
        .btn-volver { background: #444; }

        .card { background: var(--gris); padding: 20px; border-radius: 15px; border-top: 5px solid var(--rojo); max-width: 500px; margin: 10px auto; }
        .mensaje { font-size: 1.2em; font-weight: bold; margin: 15px; }
        .opcion-viva { background: #333; padding: 12px; margin: 8px; border-radius: 5px; cursor: pointer; border: 1px solid var(--rojo); transition: 0.3s; }
        .opcion-viva:hover { background: var(--rojo); }

        /* Puzzle */
        #contenedor-puzzle { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px; margin: 20px 0; }
        .pieza { background: var(--rojo); padding: 10px; border-radius: 5px; cursor: pointer; min-width: 60px; }
    </style>
</head>
<body>

    <div id="menu" class="pantalla activa">
        <h1>CARLOS FONSECA</h1>
        <img src="https://upload.wikimedia.org/wikipedia/commons/6/6f/Carlos_Fonseca_Amador.jpg" class="img-juego">
        <div class="card">
            <button class="btn" onclick="iniciarTrivia('facil')">🟢 NIVEL FÁCIL</button>
            <button class="btn" onclick="iniciarTrivia('medio')">🟡 NIVEL MEDIO</button>
            <button class="btn" onclick="iniciarTrivia('dificil')">🔴 NIVEL DIFÍCIL</button>
            <button class="btn" onclick="navegar('senderos')">🏔️ SENDEROS (HISTORIA)</button>
            <button class="btn" onclick="iniciarPuzzle()">🧩 ROMPECABEZAS</button>
        </div>
    </div>

    <div id="pantalla-trivia" class="pantalla">
        <h2 id="trivia-titulo">Trivia</h2>
        <div class="card">
            <p id="pregunta-texto">Cargando...</p>
            <div id="opciones-contenedor"></div>
        </div>
        <button class="btn btn-volver" onclick="navegar('menu')">SALIR AL MENÚ</button>
    </div>

    <div id="senderos" class="pantalla">
        <h2>SENDEROS DE ZINICA</h2>
        <img src="https://viva-nicaragua.imgix.net/2020/11/comandante-carlos-fonseca-amador-revolucion.jpg" class="img-juego">
        <div class="card">
            <p id="historia-texto">Estás en la montaña con el Comandante Carlos. La guardia se acerca. ¿Qué haces?</p>
            <div id="historia-opciones">
                <button class="btn" onclick="historia(1)">Esconderse en la maleza</button>
                <button class="btn" onclick="historia(2)">Organizar la defensa</button>
            </div>
        </div>
        <button class="btn btn-volver" onclick="navegar('menu')">VOLVER</button>
    </div>

    <div id="rompecabezas" class="pantalla">
        <h2>ORDENA LA FRASE</h2>
        <div class="card">
            <p>Haz clic en las palabras para armar la frase de Carlos:</p>
            <div id="contenedor-puzzle"></div>
            <div id="resultado-puzzle" style="border: 2px dashed var(--rojo); min-height: 40px; padding: 10px; margin-top: 10px;"></div>
            <button class="btn" style="background:green; display:none;" id="btn-verificar-p" onclick="verificarPuzzle()">VERIFICAR</button>
            <button class="btn btn-volver" onclick="limpiarPuzzle()">REINTENTAR</button>
        </div>
        <button class="btn btn-volver" onclick="navegar('menu')">MENU</button>
    </div>

    <script>
        // --- LÓGICA DE TRIVIA ---
        let preguntas = {
            facil: [
                { p: "¿En qué país nació Carlos Fonseca?", o: ["Nicaragua", "Colombia", "Cuba"], c: 0 },
                { p: "¿Qué ciudad lo vio nacer?", o: ["Managua", "Matagalpa", "León"], c: 1 },
                { p: "¿A quiénes mandó a enseñar a leer?", o: ["A los campesinos", "A los soldados", "A los ricos"], c: 0 },
                { p: "¿De qué color es su bandera?", o: ["Azul y Blanco", "Rojo y Negro", "Verde"], c: 1 },
                { p: "¿Cómo le dicen a Carlos?", o: ["El General", "Padre de la Revolución", "El profe"], c: 1 }
            ],
            medio: [
                { p: "¿En qué año nació?", o: ["1936", "1940", "1920"], c: 0 },
                { p: "¿Qué organización fundó?", o: ["FSLN", "ONU", "OEA"], c: 0 },
                { p: "¿Qué profesión tenía?", o: ["Médico", "Profesor e Intelectual", "Abogado"], c: 1 },
                { p: "¿Cómo se llamaba su mamá?", o: ["Agustina Amador", "Josefa", "María"], c: 0 },
                { p: "¿Cuál era su seudónimo?", o: ["Sandino", "Agatón", "Danto"], c: 1 }
            ],
            dificil: [
                { p: "¿Dónde cayó en combate?", o: ["Zinica", "Pancasán", "Managua"], c: 0 },
                { p: "¿En qué mes falleció?", o: ["Noviembre", "Julio", "Mayo"], c: 0 },
                { p: "¿A qué país viajó en la URSS?", o: ["Moscú", "París", "Londres"], c: 0 },
                { p: "¿Qué libro escribió?", o: ["Un Nicaragüense en Moscú", "Azul", "Cantos de Vida"], c: 0 },
                { p: "¿En qué año fundó el FSLN?", o: ["1961", "1979", "1950"], c: 0 }
            ]
        };

        let nivelActual = "";
        let preguntaActual = 0;

        function iniciarTrivia(nivel) {
            nivelActual = nivel;
            preguntaActual = 0;
            navegar('pantalla-trivia');
            mostrarPregunta();
        }

        function mostrarPregunta() {
            let datos = preguntas[nivelActual][preguntaActual];
            document.getElementById("trivia-titulo").innerText = "Nivel " + nivelActual.toUpperCase();
            document.getElementById("pregunta-texto").innerText = (preguntaActual + 1) + ". " + datos.p;
            let cont = document.getElementById("opciones-contenedor");
            cont.innerHTML = "";
            datos.o.forEach((opc, i) => {
                let div = document.createElement("div");
                div.className = "opcion-viva";
                div.innerText = opc;
                div.onclick = () => validarRespuesta(i);
                cont.appendChild(div);
            });
        }

        function validarRespuesta(idx) {
            if (idx === preguntas[nivelActual][preguntaActual].c) {
                preguntaActual++;
                if (preguntaActual < preguntas[nivelActual].length) {
                    alert("¡Correcto! Siguiente pregunta.");
                    mostrarPregunta();
                } else {
                    alert("¡FELICIDADES! Has completado el nivel " + nivelActual);
                    navegar('menu');
                }
            } else {
                alert("¡INCORRECTO! Regresas al inicio del nivel.");
                preguntaActual = 0;
                mostrarPregunta();
            }
        }

        // --- LÓGICA SENDEROS ---
        function historia(paso) {
            let txt = document.getElementById("historia-texto");
            let btnCont = document.getElementById("historia-opciones");
            if (paso === 1) {
                txt.innerText = "Te escondiste bien. Ahora Carlos te pide llevar un mensaje secreto a la ciudad. ¿Por dónde vas?";
                btnCont.innerHTML = `<button class="btn" onclick="historia(3)">Por el río</button>
                                     <button class="btn" onclick="historia(4)">Por el camino real</button>`;
            } else if (paso === 2) {
                txt.innerText = "La defensa fue dura pero ganaron tiempo. Carlos está herido. ¿Qué haces?";
                btnCont.innerHTML = `<button class="btn" onclick="historia(5)">Buscar un médico</button>
                                     <button class="btn" onclick="alert('Misión cumplida: Ayudaste a salvar al Comandante'); navegar('menu')">Cargarlo al refugio</button>`;
            } else if (paso >= 3) {
                alert("Has avanzado mucho en la historia. ¡Eres un gran colaborador!");
                navegar('menu');
            }
        }

        // --- LÓGICA PUZZLE ---
        let fraseOriginal = ["TAMBIÉN", "ENSÉÑENLES", "A", "LEER"];
        let fraseUsuario = [];

        function iniciarPuzzle() {
            navegar('rompecabezas');
            limpiarPuzzle();
        }

        function limpiarPuzzle() {
            fraseUsuario = [];
            document.getElementById("resultado-puzzle").innerText = "";
            let cont = document.getElementById("contenedor-puzzle");
            cont.innerHTML = "";
            let desordenada = [...fraseOriginal].sort(() => Math.random() - 0.5);
            desordenada.forEach(pal => {
                let btn = document.createElement("span");
                btn.className = "pieza";
                btn.innerText = pal;
                btn.onclick = () => {
                    fraseUsuario.push(pal);
                    document.getElementById("resultado-puzzle").innerText = fraseUsuario.join(" ");
                    btn.style.display = "none";
                    if(fraseUsuario.length === 4) document.getElementById("btn-verificar-p").style.display = "block";
                };
                cont.appendChild(btn);
            });
        }

        function verificarPuzzle() {
            if (fraseUsuario.join(" ") === fraseOriginal.join(" ")) {
                alert("¡EXCELENTE! Frase completada correctamente.");
                navegar('menu');
            } else {
                alert("Orden incorrecto. Intenta de nuevo.");
                limpiarPuzzle();
            }
        }

        function navegar(id) {
            document.querySelectorAll('.pantalla').forEach(p => p.classList.remove('activa'));
            document.getElementById(id).classList.add('activa');
        }
    </script>
</body>
</html>
